# ── LLM Mode ──────────────────────────────────────────────────────────────
# Options: local | cloud | hybrid
LLM_MODE=hybrid

# ── Ollama (local / on-prem) ───────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_FALLBACK_MODEL=llama3.2:3b

# ── Claude API (cloud fallback) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── ChromaDB (vector store) ────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_FAILURES=rca_failures
CHROMA_COLLECTION_DOCS=rca_docs

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org
GITHUB_REPO=vodafone-ready-networks-automation
GITHUB_RUN_FETCH_LIMIT=20

# ── Jira ───────────────────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=ankit.baijal@capgemini.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=VRN
JIRA_COMPONENT=SD-WAN-Automation
JIRA_AUTO_CREATE=true
JIRA_BUG_THRESHOLD=0.7

# ── Microsoft Teams ────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
TEAMS_STANDUP_TIME=07:30
TEAMS_TIMEZONE=Europe/London

# ── API Server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
